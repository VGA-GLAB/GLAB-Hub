{
  "name": "glab-bot",
  "version": "0.1.0",
  "private": true,
  "description": "GLAB Discord Bot — イベント通知 / 就活情報 / LLM やりとり。 GLAB hub と同じ corpus.db を共有",
  "type": "module",
  "scripts": {
    "start": "tsx --env-file-if-exists=.env index.ts",
    "dev": "tsx watch --env-file-if-exists=.env index.ts",
    "config-setup": "tsx config-setup.ts",
    "register": "tsx register.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@ludiars/encrypted-config": "0.1.0",
    "better-sqlite3": "^12.6.0",
    "discord.js": "^14.26.4",
    "tsx": "^4.20.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0"
  }
}
