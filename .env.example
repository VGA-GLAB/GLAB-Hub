# GLAB hub — 単独開発用設定。通常運用はExcubitorがspawn envへ直接注入する。
# Discord Bot の token / API キーは別系統 = 暗号化 config (bot/ で config-setup)。

# --- 認証 (必須) ---
CERNERE_BASE_URL=http://localhost:8080
# Cernere Web UI (設定/データ管理タブの動線。Excubitor catalog: cernere-frontend)
CERNERE_WEB_URL=http://localhost:5173
CERNERE_PROJECT_CLIENT_ID=
CERNERE_PROJECT_CLIENT_SECRET=
CORPUS_PUBLIC_URL=http://localhost:5187
CORPUS_ADMIN_IDS=

# --- listen / data ---
CORPUS_PORT=5187
# GLAB所有イベント（Web/Bot共通、必須）
GLAB_DATABASE_URL=postgresql://glab_user:change-me@localhost:5432/glab

# --- 動作モード (Corpus) ---
CORPUS_MODE=server
CORPUS_TOKEN_MODE=cernere-project-token

# --- 集約先サービス (空なら degraded 表示。 稼働後に設定) ---
# 施設予約 = Aedilis（イベントはGLAB PostgreSQL、出席状況はGLAB SQLiteで管理）
AEDILIS_BASE_URL=
# Wi-Fi内出席 = Ostiarius（LAN内URLのみ。Cloudflare Tunnelへ公開しない）
OSTIARIUS_URL=http://localhost:17590
# レビュー = Volputas API（設問取得・回答中継。UIはGLAB Corpus内で描画）
VOLPUTAS_URL=http://localhost:8892
# Omnipotensのローカル解析結果（Review/<project name>/reportを参照）
GLAB_OMNIPOTENS_REVIEW_ROOT=
# 議論・学習 = Discutere (Di)。Web UIが別originの場合だけWEB URLも設定
DISCUTERE_URL=http://localhost:3110
# DISCUTERE_WEB_URL=
# 企業・就活 = Tirocinium (Tr)
TIROCINIUM_URL=http://localhost:8084

# --- 単独起動時のInfisical bootstrap（Ex起動では不要） ---
# INFISICAL_SITE_URL=
# INFISICAL_PROJECT_ID=
# INFISICAL_ENVIRONMENT=dev
# INFISICAL_CLIENT_ID=
# INFISICAL_CLIENT_SECRET=
