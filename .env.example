# GLAB hub — 単独開発用設定。通常運用はExcubitorがspawn envへ直接注入する。
# Discord Bot の token / API キーは別系統 = 暗号化 config (bot/ で config-setup)。

# --- 認証 (必須) ---
CERNERE_BASE_URL=http://localhost:8080
CERNERE_PROJECT_CLIENT_ID=
CERNERE_PROJECT_CLIENT_SECRET=
CORPUS_PUBLIC_URL=http://localhost:5187
CORPUS_ADMIN_IDS=

# --- listen / data ---
CORPUS_PORT=5187

# --- 動作モード (Corpus) ---
CORPUS_MODE=server
CORPUS_TOKEN_MODE=passthrough

# --- 集約先サービス (空なら degraded 表示。 稼働後に設定) ---
# 施設予約 = Aedilis（出席状況は GLAB の SQLite で管理）
AEDILIS_BASE_URL=
# 動画レビュー = Volputas API。Web UI が別originの場合だけ VOLPUTAS_WEB_URL も設定
VOLPUTAS_URL=http://localhost:8892
# VOLPUTAS_WEB_URL=
# 議論・学習 = Discutere (Di)。Web UIが別originの場合だけWEB URLも設定
DISCUTERE_URL=http://localhost:3110
# DISCUTERE_WEB_URL=
# 企業・就活 = Tirocinium (Tr)
TIROCINIUM_URL=http://localhost:8084

# --- 集約先へ渡すサービス間 Bearer (任意。 未設定ならユーザ Bearer を透過) ---
# AEDILIS_SERVICE_TOKEN=

# --- 単独起動時のInfisical bootstrap（Ex起動では不要） ---
# INFISICAL_SITE_URL=
# INFISICAL_PROJECT_ID=
# INFISICAL_ENVIRONMENT=dev
# INFISICAL_CLIENT_ID=
# INFISICAL_CLIENT_SECRET=
